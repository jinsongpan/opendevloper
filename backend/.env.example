# Backend Environment Variables
PORT=4000

# ============ Sandbox Configuration ============
# Sandbox type: local | docker | remote
# Options:
#   - local: Local filesystem sandbox (default, fastest)
#   - docker: Docker container isolation
#   - remote: Remote gRPC service (requires sandbox-server)
# SANDBOX_TYPE=local

# Docker mode (legacy, use SANDBOX_TYPE=docker instead)
# USE_DOCKER=false

# Remote sandbox configuration (when SANDBOX_TYPE=remote)
# SANDBOX_HOST=localhost
# SANDBOX_PORT=50051
# SANDBOX_TIMEOUT=30000
# SANDBOX_FALLBACK=true
# SANDBOX_RETRIES=3

# ============ Default Providers ============
# Default Providers (optional, comma-separated)
# Options: anthropic, openai, openrouter
# DEFAULT_PROVIDERS=openrouter

# Anthropic (Claude)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# OpenAI
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# OpenRouter
# OPENROUTER_API_KEY=sk-...
# OPENROUTER_MODEL=z-ai/glm-4.5-air:free
